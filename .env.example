# Copy to .env and fill in real values. Do not commit secrets.

# --- API ---------------------------------------------------------------------
PORT=4000
DATABASE_URL=postgresql://user:pass@host:5432/postgres
DATABASE_URL_TEST=postgresql://user:pass@host:5432/postgres
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# --- Supabase (shared by API + web) ------------------------------------------
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon jwt>
SUPABASE_SERVICE_ROLE_KEY=<service role jwt>
SUPABASE_JWT_SECRET=<jwt signing secret>

# --- Web (Next.js) — inlined at build time -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon jwt>
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000
SITE_URL=http://localhost:3000

# --- Email — transactional order emails ---------------------------------------
# Preferred for localhost: Gmail SMTP. Requires 2-Step Verification on the Google
# account, then create an App Password at https://myaccount.google.com/apppasswords.
# When SMTP_* are set they take priority over Resend.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=<your@gmail.com>
SMTP_PASS=<16-char app password>
# Fallback: Resend API key (https://resend.com → API Keys). Leave both unset to log emails only.
RESEND_API_KEY=<re_xxxxxxxxxxxx>
# Sender shown to customers. Gmail rewrites the address to SMTP_USER but keeps the display name.
EMAIL_FROM=KidPulse <orders@kidpulse.lk>
# Base URL used inside email links (order pages, magic links)
WEB_BASE_URL=http://localhost:3000

# --- PayHere (sandbox) ---------------------------------------------------------
# Sandbox credentials from https://sandbox.payhere.lk → Settings → Domains & Credentials
PAYHERE_MERCHANT_ID=<12xxxxx sandbox merchant id>
PAYHERE_MERCHANT_SECRET=<sandbox merchant secret>
PAYHERE_SANDBOX=true
# Publicly reachable base URL of the Express API — PayHere posts payment
# notifications to <API_PUBLIC_URL>/api/v1/payments/payhere/notify.
# For local testing use an ngrok/cloudflared tunnel URL pointing at port 4000.
API_PUBLIC_URL=http://localhost:4000
